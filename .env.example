SKYSCANNER_API_KEY=tu_api_key_aprobada
SKYSCANNER_MARKET=CL
SKYSCANNER_LOCALE=es-CL

# Opcional: scraping estilo Flight Finder/Google Flights.
# Requiere: python3 -m pip install '.[scraping]' && python3 -m playwright install chromium
FARESNIPE_SCRAPER_COUNTRY=CL
FARESNIPE_SCRAPER_LANGUAGE=en
FARESNIPE_SCRAPER_SETTLE_SECONDS=8
FARESNIPE_SCRAPER_TIMEOUT_SECONDS=45

# Opcional: alertas directas por Telegram.
FARESNIPE_TELEGRAM_BOT_TOKEN=123456:token
FARESNIPE_TELEGRAM_CHAT_ID=123456789
